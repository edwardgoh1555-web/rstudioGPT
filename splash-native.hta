<html>
<head>
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<title>R/StudioGPT</title>
<HTA:APPLICATION
    ID="SplashScreen"
    APPLICATIONNAME="R/StudioGPT"
    BORDER="none"
    BORDERSTYLE="none"
    CAPTION="no"
    CONTEXTMENU="no"
    INNERBORDER="no"
    MAXIMIZEBUTTON="no"
    MINIMIZEBUTTON="no"
    NAVIGABLE="no"
    SCROLL="no"
    SCROLLFLAT="no"
    SELECTION="no"
    SHOWINTASKBAR="no"
    SINGLEINSTANCE="yes"
    SYSMENU="no"
    VERSION="1.0"
    WINDOWSTATE="normal"
/>
<script>
// Resize and center immediately
window.resizeTo(400, 450);
window.moveTo((screen.width - 400) / 2, (screen.height - 450) / 2);
</script>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body {
    width: 400px;
    height: 450px;
    background: #0f0f23;
    font-family: 'Segoe UI', Tahoma, sans-serif;
    overflow: hidden;
    display: -ms-flexbox;
    display: flex;
    -ms-flex-align: center;
    align-items: center;
    -ms-flex-pack: center;
    justify-content: center;
}
.splash-container {
    text-align: center;
    animation: fadeIn 0.5s ease-out;
}
@keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
}
.logo-container {
    position: relative;
    width: 120px;
    height: 120px;
    margin: 0 auto 30px;
}
.logo-ring {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    border-radius: 50%;
    border: 3px solid transparent;
    border-top-color: #6366f1;
    animation: spin 1.2s linear infinite;
}
.logo-ring.r2 {
    top: 10px; left: 10px; right: 10px; bottom: 10px;
    border-top-color: #8b5cf6;
    animation-duration: 1s;
    animation-direction: reverse;
}
.logo-ring.r3 {
    top: 20px; left: 20px; right: 20px; bottom: 20px;
    border-top-color: #a78bfa;
    animation-duration: 0.8s;
}
@keyframes spin { to { transform: rotate(360deg); } }
.logo-center {
    position: absolute;
    top: 30px; left: 30px; right: 30px; bottom: 30px;
    background: #6366f1;
    background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
    border-radius: 50%;
    display: -ms-flexbox;
    display: flex;
    -ms-flex-align: center;
    align-items: center;
    -ms-flex-pack: center;
    justify-content: center;
    box-shadow: 0 0 40px rgba(99, 102, 241, 0.5);
}
.logo-text {
    font-size: 24px;
    font-weight: 700;
    color: white;
    letter-spacing: -1px;
}
.app-name {
    font-size: 32px;
    font-weight: 700;
    color: #a78bfa;
    margin-bottom: 8px;
    text-shadow: 0 0 30px rgba(167, 139, 250, 0.5);
}
.app-tagline {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.45);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 40px;
}
.loading-bar-container {
    width: 200px;
    height: 4px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 2px;
    margin: 0 auto;
    overflow: hidden;
}
.loading-bar {
    height: 100%;
    width: 30%;
    background: linear-gradient(90deg, #6366f1, #a78bfa);
    border-radius: 2px;
    animation: loading 1.2s ease-in-out infinite;
}
@keyframes loading {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(450%); }
}
.loading-text {
    margin-top: 20px;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.35);
    letter-spacing: 1px;
    animation: pulse 2s ease-in-out infinite;
}
@keyframes pulse {
    0%, 100% { opacity: 0.35; }
    50% { opacity: 0.7; }
}
.version {
    position: absolute;
    bottom: 20px;
    left: 0;
    right: 0;
    text-align: center;
    font-size: 11px;
    color: rgba(255, 255, 255, 0.15);
}
/* Glow effects */
.glow-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0.3;
    animation: float 4s ease-in-out infinite;
}
.glow-orb.purple {
    width: 150px;
    height: 150px;
    background: #8b5cf6;
    top: 50px;
    left: 30px;
}
.glow-orb.blue {
    width: 120px;
    height: 120px;
    background: #6366f1;
    bottom: 80px;
    right: 40px;
    animation-delay: -2s;
}
@keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-15px); }
}
</style>
</head>
<body>
    <div class="glow-orb purple"></div>
    <div class="glow-orb blue"></div>
    <div class="splash-container">
        <div class="logo-container">
            <div class="logo-ring"></div>
            <div class="logo-ring r2"></div>
            <div class="logo-ring r3"></div>
            <div class="logo-center">
                <span class="logo-text">R/</span>
            </div>
        </div>
        <h1 class="app-name">R/StudioGPT</h1>
        <p class="app-tagline">Narrative Intelligence</p>
        <div class="loading-bar-container">
            <div class="loading-bar"></div>
        </div>
        <p class="loading-text">Initializing...</p>
    </div>
    <div class="version">v1.0.0</div>
</body>
</html>
